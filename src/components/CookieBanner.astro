---
// Banner de cookies LGPD
---
<div id="cookie-banner" class="cookie-banner" role="dialog" aria-label="Aviso de cookies" aria-live="polite">
  <div class="cookie-content">
    <p>Utilizamos cookies para melhorar sua experiência e analisar o tráfego do site, em conformidade com a <strong>LGPD</strong>. Ao continuar navegando, você concorda com o uso de cookies. <a href="/privacidade">Saiba mais</a>.</p>
    <div class="cookie-actions">
      <button id="cookie-accept" class="cookie-btn cookie-btn-primary">Aceitar</button>
      <button id="cookie-reject" class="cookie-btn cookie-btn-secondary">Recusar</button>
    </div>
  </div>
</div>
<style>
  .cookie-banner { position: fixed; bottom: 1rem; left: 1rem; right: 1rem; max-width: 600px; margin: 0 auto; background: #1f2937; color: #f9fafb; border-radius: 12px; padding: 1rem 1.25rem; z-index: 9999; box-shadow: 0 4px 24px rgba(0,0,0,0.25); display: none; }
  .cookie-banner.visible { display: block; }
  .cookie-content { display: flex; flex-direction: column; gap: 0.875rem; }
  .cookie-content p { font-size: 0.875rem; margin: 0; line-height: 1.5; color: #e5e7eb; }
  .cookie-content a { color: #60a5fa; }
  .cookie-actions { display: flex; gap: 0.5rem; }
  .cookie-btn { padding: 0.5rem 1.25rem; border-radius: 7px; font-size: 0.875rem; font-weight: 600; cursor: pointer; border: none; transition: opacity 0.2s; }
  .cookie-btn-primary { background: var(--color-primary, #2563eb); color: #fff; }
  .cookie-btn-secondary { background: transparent; color: #9ca3af; border: 1px solid #374151; }
  .cookie-btn:hover { opacity: 0.88; }
</style>
<script is:inline>
  (function(){
    const banner = document.getElementById('cookie-banner');
    const accept = document.getElementById('cookie-accept');
    const reject = document.getElementById('cookie-reject');
    if (!localStorage.getItem('cookie-consent')) banner?.classList.add('visible');
    accept?.addEventListener('click', function() { localStorage.setItem('cookie-consent','accepted'); banner?.classList.remove('visible'); });
    reject?.addEventListener('click', function() { localStorage.setItem('cookie-consent','rejected'); banner?.classList.remove('visible'); });
  })();
</script>
