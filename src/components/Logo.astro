---
// Componente de logo com fallback
---
<picture class="logo-picture">
  <source srcset="/images/brand/logo-horizontal.svg" type="image/svg+xml">
  <img
    src="/images/brand/logo-horizontal.png"
    alt="InSpotGO - Análises de Software & SaaS"
    class="logo-desktop"
    width="250"
    height="60"
    loading="eager"
  >
</picture>

<style>
  .logo-picture {
    display: inline-block;
  }

  .logo-desktop {
    height: 60px;
    width: auto;
    display: block;
  }
</style>
