---
import { SITE_CONFIG } from '../config';
const year = new Date().getFullYear();
---

<footer class="footer" role="contentinfo">
  <div class="container">
    <div class="footer-content">
      <div class="footer-brand">
        <a href="/" class="footer-logo-link" aria-label="InSpotGO BR — página inicial">
          <img src="/images/brand/logo.png" alt="" class="footer-logo-icon" height="38" width="38" />
          <div class="footer-logo-text">
            <span class="logo-spot">InSpot</span><span class="logo-go">GO</span><span class="logo-br-badge">BR</span>
          </div>
        </a>
        <p class="footer-tagline">Encontre o Melhor. Decida com Confiança.</p>
        <p class="footer-description">Reviews independentes de SaaS e software — ajudando profissionais e empresas brasileiras a escolher as melhores ferramentas digitais.</p>
      </div>

      <div class="footer-links">
        <div class="footer-column">
          <h4>Categorias</h4>
          <a href="/saas">SaaS</a>
          <a href="/software">Software</a>
          <a href="/comparativos">Comparativos</a>
          <a href="/guias">Guias de Compra</a>
        </div>

        <div class="footer-column">
          <h4>Empresa</h4>
          <a href="/sobre">Sobre Nós</a>
          <a href="/contato">Contato</a>
          <a href="/politica-editorial">Política Editorial</a>
        </div>

        <div class="footer-column">
          <h4>Legal</h4>
          <a href="/privacidade">Política de Privacidade</a>
          <a href="/termos">Termos de Uso</a>
          <a href="/disclosure">Divulgação de Afiliados</a>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <p class="footer-copyright">© {year} {SITE_CONFIG.legalEntity}. Todos os direitos reservados.</p>
      <p class="footer-disclaimer">O InSpotGO BR é sustentado pelos leitores. Quando você compra através de links neste site, podemos receber uma comissão de afiliado sem custo adicional para você.</p>
    </div>
  </div>
</footer>

<style>
  .footer { background: var(--color-bg-alt); border-top: 1px solid var(--color-border); padding: 3rem 0 2rem; margin-top: 4rem; }
  .footer-content { display: grid; grid-template-columns: 1.5fr 2fr; gap: 3rem; max-width: 1400px; margin: 0 auto; padding: 0 1.5rem; }
  .footer-brand { display: flex; flex-direction: column; gap: 0.75rem; }
  .footer-logo-link { display: inline-flex; align-items: center; gap: 0.5rem; text-decoration: none; margin-bottom: 0.25rem; transition: transform 0.25s; }
  .footer-logo-link:hover { transform: scale(1.04); }
  .footer-logo-icon { display: block; flex-shrink: 0; }
  .footer-logo-text { font-size: 1.2rem; font-weight: 800; letter-spacing: -0.02em; display: flex; align-items: center; gap: 0; line-height: 1.2; }
  .logo-spot { color: var(--color-primary); }
  .logo-go { background: var(--gradient-logo-go, linear-gradient(90deg,#f97316,#ec4899)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
  .logo-br-badge { font-size: 0.8rem; font-weight: 700; color: #fff; background: #10b981; border-radius: 5px; padding: 0.1rem 0.4rem; letter-spacing: 0.04em; -webkit-text-fill-color: #fff; }
  .footer-tagline { color: var(--color-text); font-size: 0.95rem; font-weight: 600; margin: 0; }
  .footer-description { color: var(--color-text-light); font-size: 0.85rem; line-height: 1.6; margin: 0; max-width: 280px; }
  .footer-links { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; }
  .footer-column { display: flex; flex-direction: column; gap: 0.75rem; }
  .footer-column h4 { color: var(--color-text); font-size: 1rem; font-weight: 600; margin: 0 0 0.5rem 0; }
  .footer-column a { color: var(--color-text-light); text-decoration: none; font-size: 0.9rem; transition: color 0.2s; }
  .footer-column a:hover { color: var(--color-primary); }
  .footer-bottom { padding-top: 2rem; border-top: 1px solid var(--color-border); max-width: 1400px; margin: 2rem auto 0; padding-left: 1.5rem; padding-right: 1.5rem; color: var(--color-text-light); font-size: 0.9rem; text-align: center; }
  .footer-copyright, .footer-disclaimer { margin: 0; }
  .footer-disclaimer { margin-top: 0.5rem; font-size: 0.82rem; }
  @media (max-width: 768px) {
    .footer { padding: 2rem 0 1.5rem; }
    .footer-content { grid-template-columns: 1fr; gap: 2rem; padding: 0 1rem; }
    .footer-links { grid-template-columns: 1fr 1fr; gap: 1.5rem; }
    .footer-bottom { padding-left: 1rem; padding-right: 1rem; }
    .footer-description { max-width: 100%; }
  }
</style>
