---
import BaseLayout from './BaseLayout.astro';
import { SITE_CONFIG } from '../config';

interface Props {
  title: string;
  description: string;
  date?: Date | string;
  readTime?: string;
  author?: string;
  cover?: string;
  category?: string;
  tags?: string[];
}

const {
  title,
  description,
  date,
  readTime,
  author = 'Editorial InSpotGO BR',
  cover,
  category,
  tags = [],
} = Astro.props;

const formattedDate = date ? new Date(date).toLocaleDateString('pt-BR', {
  year: 'numeric', month: 'long', day: 'numeric'
}) : null;

const publishedTime = date ? new Date(date).toISOString() : undefined;
---

<BaseLayout
  title={title}
  description={description}
  article={true}
  showAffiliateBanner={true}
  publishedTime={publishedTime}
>
  <article class="post">
    <div class="container">
      <header class="post-header">
        {category && <a href={`/${category.toLowerCase()}`} class="post-category">{category}</a>}
        <h1 class="post-title">{title}</h1>
        <p class="post-description">{description}</p>
        <div class="post-meta">
          {author && <span class="post-author">Por {author}</span>}
          {formattedDate && <span class="post-date">{formattedDate}</span>}
          {readTime && <span class="post-read-time">{readTime} de leitura</span>}
        </div>
      </header>

      {cover && (
        <div class="post-cover">
          <img src={cover} alt={title} loading="eager" decoding="async" />
        </div>
      )}

      <div class="post-body prose">
        <slot />
      </div>

      {tags.length > 0 && (
        <div class="post-tags">
          {tags.map(tag => (
            <span class="post-tag">{tag}</span>
          ))}
        </div>
      )}
    </div>
  </article>
</BaseLayout>

<style>
  .post { padding: 2rem 0 4rem; }
  .post-header { max-width: 760px; margin: 0 auto 2rem; text-align: center; }
  .post-category { display: inline-block; background: var(--color-primary); color: #fff; font-size: 0.75rem; font-weight: 600; padding: 0.2rem 0.75rem; border-radius: 100px; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 1rem; text-decoration: none; transition: background 0.2s ease, transform 0.2s ease; }
  .post-category:hover { background: var(--color-primary-dark, #5a67d8); transform: translateY(-1px); }
  .post-title { font-size: clamp(1.75rem, 4vw, 2.75rem); font-weight: 800; line-height: 1.15; letter-spacing: -0.02em; color: var(--color-text); margin-bottom: 1rem; }
  .post-description { font-size: 1.1rem; color: var(--color-text-light); line-height: 1.6; margin-bottom: 1.25rem; }
  .post-meta { display: flex; align-items: center; justify-content: center; gap: 1rem; flex-wrap: wrap; font-size: 0.875rem; color: var(--color-text-lighter); }
  .post-meta span::before { content: '•'; margin-right: 1rem; }
  .post-meta span:first-child::before { content: ''; margin-right: 0; }
  .post-cover { max-width: 900px; margin: 0 auto 2.5rem; border-radius: 12px; overflow: hidden; }
  .post-cover img { width: 100%; height: auto; display: block; }
  .post-body { max-width: 760px; margin: 0 auto; }
  .prose h2 { font-size: 1.5rem; font-weight: 700; margin: 2rem 0 0.75rem; color: var(--color-text); }
  .prose h3 { font-size: 1.2rem; font-weight: 600; margin: 1.5rem 0 0.5rem; color: var(--color-text); }
  .prose p { margin-bottom: 1.25rem; line-height: 1.75; }
  .prose ul, .prose ol { margin: 0 0 1.25rem 1.5rem; }
  .prose li { margin-bottom: 0.4rem; line-height: 1.7; }
  .prose table { width: 100%; border-collapse: collapse; margin: 1.5rem 0; font-size: 0.9rem; }
  .prose th { background: var(--color-bg-alt); font-weight: 600; padding: 0.75rem 1rem; text-align: left; border: 1px solid var(--color-border); }
  .prose td { padding: 0.65rem 1rem; border: 1px solid var(--color-border); }
  .prose tr:nth-child(even) td { background: var(--color-bg-alt); }
  .prose a { color: var(--color-primary); font-weight: 500; }
  .prose blockquote { border-left: 4px solid var(--color-primary); padding: 1rem 1.25rem; margin: 1.5rem 0; background: #eff6ff; border-radius: 0 8px 8px 0; font-style: italic; color: var(--color-text-light); }
  .prose strong { font-weight: 700; }
  .prose code { background: #f3f4f6; padding: 0.15rem 0.4rem; border-radius: 4px; font-size: 0.875em; font-family: var(--font-mono); }
  .prose hr { border: none; border-top: 1px solid var(--color-border); margin: 2.5rem 0; }
  .post-tags { max-width: 760px; margin: 2.5rem auto 0; display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .post-tag { background: var(--color-bg-alt); color: var(--color-text-light); font-size: 0.8rem; padding: 0.3rem 0.75rem; border-radius: 100px; border: 1px solid var(--color-border); }
  @media (max-width: 768px) {
    .post { padding: 1.5rem 0 3rem; }
    .post-header { text-align: left; }
    .post-meta { justify-content: flex-start; }
    .prose table { font-size: 0.82rem; }
    .prose th, .prose td { padding: 0.5rem 0.65rem; }
  }
</style>
